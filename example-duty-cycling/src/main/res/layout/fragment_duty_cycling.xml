<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Duty Cycling Status"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Initializing..."
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/last_change_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last state change: --"
        android:textSize="14sp"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/log_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="View Logs"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This app demonstrates duty cycling:\n\n• When the app is open (screen ON):\n  Continuous monitoring is ACTIVE\n\n• When the app is minimized (screen OFF):\n  Continuous monitoring is PAUSED\n\n• All state changes are logged and saved\n• Check logs for detailed history"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="32dp" />

</LinearLayout>
